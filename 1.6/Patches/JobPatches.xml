<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <Operation Class="PatchOperationAddModExtension">
        <xpath>/Defs/JobDef[defName="Mine"
            or defName="Harvest"
            or defName="FinishFrame"
            or defName="HarvestDesignated"
            or defName="Deconstruct"
            or defName="DeconstructForBlueprint"
            or defName="SmoothFloor"
            or defName="RemoveFloor"
            or defName="RemoveFoundation"
            or defName="SmoothWall"
            or defName="Repair"]</xpath>
        <value>
            <li Class="PerspectiveShift.JobRequiresHoldExtension" />
        </value>
    </Operation>

    <!-- <Operation Class="PatchOperationAddModExtension">
        <xpath>/Defs/JobDef[defName="DisconnectMech"]</xpath>
        <value>
            <li Class="PerspectiveShift.DisableLeftClickExtension" />
        </value>
    </Operation> -->
   
    <Operation Class="PatchOperationAddModExtension">
        <xpath>/Defs/JobDef[defName="DisassembleMech"]</xpath>
        <value>
            <li Class="PerspectiveShift.DisableLeftClickExtension" />
        </value>
    </Operation>


</Patch>
