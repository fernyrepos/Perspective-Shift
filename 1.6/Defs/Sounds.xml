<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <SoundDef>
        <defName>PS_PackInventory</defName>
        <maxSimultaneous>1</maxSimultaneous>
        <subSounds>
            <li>
                <onCamera>True</onCamera>
                <grains>
                    <li Class="AudioGrain_Clip">
                        <clipPath>PS_PackInventory</clipPath>
                    </li>
                </grains>
                <volumeRange>150~150</volumeRange>
            </li>
        </subSounds>
    </SoundDef>

